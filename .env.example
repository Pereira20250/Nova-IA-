# T.I Assistant - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# OpenAI API Key (obtenha em: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-seu-chave-aqui

# Modelo OpenAI a usar (padrão: gpt-3.5-turbo)
# Opções: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
OPENAI_MODEL=gpt-3.5-turbo

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente (development ou production)
NODE_ENV=production
